# DB: 로컬은 SQLite 기본값 사용, Docker 배포 시 아래 PostgreSQL URL로 교체
DATABASE_URL=sqlite+aiosqlite:///./babdongmu.db
# DATABASE_URL=postgresql+psycopg://babdongmu:babdongmu1234@postgres:5432/babdongmu

# JWT
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CoolSMS (=Solapi) (SMS 발송 서비스)
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER=등록된-발신번호

# Gemini (AI 요약 기능)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-preview

# ADMIN 
ADMIN_EMAIL=admin@babdongmu.com
ADMIN_PASSWORD=원하는비밀번호
ADMIN_NAME=관리자